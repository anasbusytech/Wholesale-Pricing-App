generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean?
  locale        String?
  collaborator  Boolean? @default(false)
  emailVerified Boolean? @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?  
}

model WholesaleRule {
  id                     String   @id @default(uuid())

  shopDomain             String

  name                   String

  enabled                Boolean  @default(true)

  customerTags           Json?

  quantityDropdown       Json?

  quantityInputEnabled   Boolean  @default(false)

  widgetConfig           Json?

  createdAt              DateTime @default(now())

  updatedAt              DateTime @updatedAt

  products               RuleProduct[]

  slabs                  PricingSlab[]

  discountId             String?

  eligibilityType        String @default("all") 

  customerIds            Json? 
  
  shopifyDiscountId      String?
}

model RuleProduct {
  id          String @id @default(uuid())

  ruleId      String

  productId   String

  variantId   String?
  
  rule        WholesaleRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
}

model PricingSlab {
  id          String @id @default(uuid())

  ruleId      String

  minQty      Int

  maxQty      Int?

  price       Float

  rule        WholesaleRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
}